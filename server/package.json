{
	"name": "server",
	"version": "1.0.50",
	"scripts": {
		"start": "NODE_ENV=pro bun --env-file=../.env run dist/index.js",
		"build": "tsc",
		"dev": "NODE_ENV=dev bun --env-file=../.env.dev run --watch src/index.ts",
		"generate": "bun --env-file=../.env.dev drizzle-kit generate",
		"migrate:dev": "bun --env-file=../.env.dev drizzle-kit migrate",
		"migrate": "bun --env-file=../.env drizzle-kit migrate",
		"push": "bun --env-file=../.env.dev drizzle-kit push",
		"studio": "bun --env-file=../.env.dev drizzle-kit studio"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"drizzle-orm": "^0.45.1",
		"elysia": "latest",
		"elysia-rate-limit": "^4.5.1",
		"logixlysia": "^6.2.2",
		"postgres": "^3.4.8"
	},
	"devDependencies": {
		"bun-types": "latest",
		"drizzle-kit": "^0.31.10"
	},
	"module": "src/index.js"
}
